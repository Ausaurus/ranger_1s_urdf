  <gazebo reference="depth_link_l">
    <sensor name="depth_sensor_l" type="gpu_lidar">
      <ignition_frame_id>depth_link_l</ignition_frame_id>
      <topic>lidar_l</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>false</visualize> <!-- Keep false to save resources unless debugging rays -->
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-0.50705</min_angle>
            <max_angle>0.50705</max_angle>
          </horizontal>
          <vertical>
            <samples>100</samples> <!-- 16 vertical slices provides a good 3D point cloud -->
            <resolution>1</resolution>
            <min_angle>-0.39445</min_angle> <!-- -15 degrees -->
            <max_angle>0.39445</max_angle>  <!-- +15 degrees -->
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>15.0</max> <!-- 15 meter range is typical -->
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo reference="depth_link_r">
